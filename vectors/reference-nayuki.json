    {
      "id": "reference.nayuki.binary-0041ff4200.v1-q-mask7",
      "title": "Binary 0041ff4200 fixed Version 1-Q mask 7",
      "category": "reference-matrix",
      "operation": "generate",
      "input": {
        "binaryHex": "0041ff4200"
      },
      "options": {
        "version": 1,
        "errorCorrectionLevel": "Q",
        "maskPattern": 7
      },
      "expect": {
        "referenceMatrix": {
          "adapter": "nayuki",
          "exact": true,
          "scope": "fixed-version-ecc-mask"
