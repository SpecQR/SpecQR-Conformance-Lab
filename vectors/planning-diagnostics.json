  "vectors": [
    {
      "id": "planning.estimate.byte-simple-success",
      "title": "Estimate simple byte text",
      "category": "planning-diagnostics",
      "operation": "estimate",
      "input": {
        "text": "HELLO SPECQR"
      },
      "options": {
        "errorCorrectionLevel": "M",
        "mode": "byte"
      },
      "expect": {
        "planning": {
          "ok": true,
          "selectedVersion": 1,
          "minVersion": 1,
          "maxVersion": 40,
          "errorCorrectionLevel": "M",
          "mode": "byte",
          "dataBitLength": 108,
          "capacityBits": 128,
          "remainingBits": 20,
          "diagnostics": {
            "subset": {
              "phase": "planning",
              "renderPlanned": false,
              "maskEvaluated": false,
              "codewordsBuilt": false,
              "version": 1,
              "mode": "byte",
              "segments": [
                {
                  "mode": "byte",
                  "characterCount": 12,
                  "byteCount": 12,
                  "bitLength": 108
                }
              ]
            }
          }
        }
      },
      "tags": ["planning", "estimate", "byte"]
    },
